# keep git fast, ignore normal Windows directories
/*
!/AppData
!/git
!/README.md
!/AGENTS.md
!/.gitattributes
!/setup.ps1
!/.keynavrc
!/.inputrc
!/bin

!/.config
!/.config/**
!/.agents
!/.agents/**

!/AppData/Local
AppData/Local/*
!AppData/Local/nvim
!AppData/Local/nvim/**

AppData/LocalLow/*
AppData/Roaming/*
!scoop/persist/btop/btop.conf

projects/*

!/.pi
/.pi/*
!/.pi/agent
/.pi/agent/*
!/.pi/agent/settings.json
!/.pi/agent/auth.json
